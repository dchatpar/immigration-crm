{
  "permissions": {
    "allow": [
      "Bash(npx:*)",
      "Bash(npm install:*)",
      "Bash(env:*)",
      "Bash(curl:*)",
      "Bash(# Check if there''s model info in agent logs or config cat /root/development/apps/immigration/.claude-flow/metrics/agent-metrics.json)",
      "Bash(sudo apt update:*)",
      "Bash(sudo apt install:*)",
      "Bash(snap install:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:release-assets.githubusercontent.com)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "claude-flow"
  ],
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
