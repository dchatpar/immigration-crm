# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/immigration_crm?schema=public"

# Authentication
NEXTAUTH_SECRET="your-super-secret-jwt-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Redis (for sessions and caching)
REDIS_URL="redis://localhost:6379"

# File Upload
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="immigration-crm-documents"

# Twilio (for calls/SMS)
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# SendGrid (for emails)
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@immigration-crm.com"
EMAIL_FROM="noreply@immigration-crm.com"

# Cron Security
CRON_SECRET="your-cron-secret-key-change-in-production"

# OpenAI (for AI features)
OPENAI_API_KEY="your-openai-api-key"

# App Configuration
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Rate Limiting
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# JWT
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-key-change-in-production"

# Monitoring
SENTRY_DSN="your-sentry-dsn-if-using-sentry"

# Prisma
DIRECT_URL="postgresql://postgres:password@localhost:5432/immigration_crm?schema=public"